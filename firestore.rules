rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Public content: anyone can read, only authenticated officers can write.
    match /officers/{officerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Outgoing mail queue for the Trigger Email extension.
    // Written only by the server (Admin SDK bypasses rules); no client access.
    match /mail/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
